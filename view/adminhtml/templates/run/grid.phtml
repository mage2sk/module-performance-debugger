            <?= $block->escapeHtml(__('No runs match the current filters. Adjust the filters above or load any storefront page from an allowed IP to capture a new run.')) ?>
        </div>
    <?php else: ?>
        <table>
            <thead>
                <tr>
                    <th><?= /* @noEscape */ $colHeader('run_id', __('#')) ?></th>
