$runs = $block->getRuns();
$total = $block->getTotal();
$page = $block->getPage();
$pageSize = $block->getPageSize();
$totalPages = $block->getTotalPages();
$sort = $block->getSort();
$dir = $block->getDir();
$q = $block->getQuery();
$sevFilter = $block->getMinSeverity();
$severityClass = function (int $w): string {
    return ['', 'low', 'medium', 'high', 'critical'][$w] ?? 'low';
};
$severityName = function (int $w): string {
    return ['', 'low', 'medium', 'high', 'critical'][$w] ?? '';
};
$colHeader = function (string $column, string $label) use ($block, $sort, $dir) {
    $arrow = $block->sortIndicator($column);
    $active = $sort === $column ? ' active' : '';
    return '<a href="' . $block->escapeUrl($block->sortUrl($column))
        . '" class="panth-sort' . $active . '">'
        . $block->escapeHtml($label)
        . ' <span class="arrow">' . $arrow . '</span></a>';
};

$first = $total === 0 ? 0 : (($page - 1) * $pageSize + 1);
$last = min($page * $pageSize, $total);
?>
