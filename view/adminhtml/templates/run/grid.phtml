                    <th><?= /* @noEscape */ $colHeader('route', __('Route')) ?></th>
                    <th><?= /* @noEscape */ $colHeader('url', __('URL')) ?></th>
                    <th><?= /* @noEscape */ $colHeader('total_time', __('Total ms')) ?></th>
                    <th><?= /* @noEscape */ $colHeader('db_queries', __('Queries')) ?></th>
                    <th><?= /* @noEscape */ $colHeader('db_slow', __('Slow')) ?></th>
                    <th><?= /* @noEscape */ $colHeader('db_duplicates', __('Dupes')) ?></th>
                    <th><?= /* @noEscape */ $colHeader('bottleneck_count', __('Issues')) ?></th>
                    <th><?= /* @noEscape */ $colHeader('severity_max', __('Severity')) ?></th>
                    <th><?= $block->escapeHtml(__('Actions')) ?></th>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($runs as $run): ?>
                    <?php $sevW = (int) $run['severity_max']; $sevClass = $severityClass($sevW); ?>
                    <tr>
                        <td><?= (int) $run['run_id'] ?></td>
                        <td style="white-space:nowrap"><?= $block->escapeHtml($run['created_at']) ?></td>
                        <td><?= $block->escapeHtml($run['route']) ?></td>
                        <td><span class="panth-perf-url-trunc" title="<?= $block->escapeHtmlAttr($run['url']) ?>"><?= $block->escapeHtml($run['url']) ?></span></td>
                        <td><?= $block->escapeHtml(number_format((float) $run['total_time'], 1)) ?></td>
                        <td><?= (int) $run['db_queries'] ?></td>
                        <td><?= (int) $run['db_slow'] ?></td>
                        <td><?= (int) $run['db_duplicates'] ?></td>
                        <td><?= (int) $run['bottleneck_count'] ?></td>
                        <td><?php if ($sevW > 0): ?>
                            <span class="panth-perf-sev <?= $block->escapeHtmlAttr($sevClass) ?>"><?= $block->escapeHtml($severityName($sevW)) ?></span>
                        <?php endif; ?></td>
                        <td class="panth-perf-actions">
                            <a href="<?= $block->escapeUrl($block->getViewUrl((int) $run['run_id'])) ?>"><?= $block->escapeHtml(__('View')) ?></a>
                            <a href="<?= $block->escapeUrl($block->getXlsUrl((int) $run['run_id'])) ?>"><?= $block->escapeHtml(__('XLS')) ?></a>
                            <a href="<?= $block->escapeUrl($block->getPdfUrl((int) $run['run_id'])) ?>" target="_blank"><?= $block->escapeHtml(__('PDF')) ?></a>
                        </td>
                    </tr>
                <?php endforeach; ?>
            </tbody>
        </table>

        <?php
        $pagerWindow = 5;
        $start = max(1, $page - intdiv($pagerWindow, 2));
        $end   = min($totalPages, $start + $pagerWindow - 1);
        $start = max(1, $end - $pagerWindow + 1);
        ?>
        <div class="panth-perf-pager">
            <div class="info"><?= $block->escapeHtml(__('Showing %1–%2 of %3', $first, $last, number_format($total))) ?></div>
            <div class="nums">
                <?php if ($page > 1): ?>
                    <a href="<?= $block->escapeUrl($block->gridUrl(['p' => 1])) ?>" title="<?= $block->escapeHtmlAttr(__('First')) ?>">«</a>
                    <a href="<?= $block->escapeUrl($block->gridUrl(['p' => $page - 1])) ?>" title="<?= $block->escapeHtmlAttr(__('Previous')) ?>">‹</a>
                <?php else: ?>
                    <span class="pg disabled">«</span><span class="pg disabled">‹</span>
                <?php endif; ?>

                <?php for ($i = $start; $i <= $end; $i++): ?>
                    <?php if ($i === $page): ?>
                        <span class="pg current"><?= $i ?></span>
                    <?php else: ?>
                        <a href="<?= $block->escapeUrl($block->gridUrl(['p' => $i])) ?>"><?= $i ?></a>
                    <?php endif; ?>
                <?php endfor; ?>

                <?php if ($page < $totalPages): ?>
                    <a href="<?= $block->escapeUrl($block->gridUrl(['p' => $page + 1])) ?>" title="<?= $block->escapeHtmlAttr(__('Next')) ?>">›</a>
                    <a href="<?= $block->escapeUrl($block->gridUrl(['p' => $totalPages])) ?>" title="<?= $block->escapeHtmlAttr(__('Last')) ?>">»</a>
                <?php else: ?>
                    <span class="pg disabled">›</span><span class="pg disabled">»</span>
                <?php endif; ?>
            </div>
            <div class="info"><?= $block->escapeHtml(__('Page %1 of %2', $page, $totalPages)) ?></div>
        </div>
    <?php endif; ?>
</div>
