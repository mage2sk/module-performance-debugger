    bulb:  '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"><path d="M9 18h6M10 22h4M12 2a7 7 0 00-4 12.7c.7.6 1 1.4 1 2.3v1h6v-1c0-.9.3-1.7 1-2.3A7 7 0 0012 2z"/></svg>',
    close: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>',
    chevR: '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M9 18l6-6-6-6"/></svg>',
    chevL: '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M15 18l-6-6 6-6"/></svg>',
    copy:  '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>'
  };

  var worst = (data.findings||[]).reduce(function(acc,f){
    var w={low:1,medium:2,high:3,critical:4}[f.severity]||0;
    return w>acc?w:acc;
  },0);
  var launcherCls = ['','low','med','high','crit'][worst]||'';
  var counts = {
    block: (data.aggregates&&data.aggregates.block&&data.aggregates.block.count)||0,
    observer: (data.aggregates&&data.aggregates.observer&&data.aggregates.observer.count)||0,
    query: (data.aggregates&&data.aggregates.query&&data.aggregates.query.count)||0,
    layout: (data.aggregates&&data.aggregates.layout&&data.aggregates.layout.count)||0,
    findings: (data.userlandFindings||[]).length,
    coreFindings: (data.coreFindings||[]).length
  };
  // Worst severity is computed across USERLAND only — core findings should
  // never raise the launcher to red since they're not actionable.
  worst = (data.userlandFindings||[]).reduce(function(acc,f){
    var w={low:1,medium:2,high:3,critical:4}[f.severity]||0;
    return w>acc?w:acc;
  },0);
  launcherCls = ['','low','med','high','crit'][worst]||'';

  var copyToClipboard = function(text){
    try {
      navigator.clipboard.writeText(text);
      showToast('Copied!');
    } catch(e) {
      var t = document.createElement('textarea');
      t.value = text; document.body.appendChild(t); t.select();
