    +       '</div>'
    +     '</div>'
    +     '<button class="panth-pdbg-close" data-pdbg="close" aria-label="Close">'+ico.close+'</button>'
    +   '</div>'
    +   '<div class="panth-pdbg-tabs" role="tablist">'
    +     '<button class="panth-pdbg-tab active" data-tab="overview" role="tab">'+ico.home+'<span>Overview</span></button>'
    +     '<button class="panth-pdbg-tab" data-tab="timeline" role="tab">'+ico.list+'<span>Timeline</span></button>'
    +     '<button class="panth-pdbg-tab" data-tab="queries" role="tab">'+ico.db+'<span>Queries</span>'+(counts.query?'<span class="badge">'+counts.query+'</span>':'')+'</button>'
    +     '<button class="panth-pdbg-tab" data-tab="modules" role="tab">'+ico.box+'<span>Modules</span></button>'
    +     '<button class="panth-pdbg-tab" data-tab="bottlenecks" role="tab">'+ico.alert+'<span>Issues</span>'+(counts.findings?'<span class="badge crit">'+counts.findings+'</span>':'')+'</button>'
    +     '<button class="panth-pdbg-tab" data-tab="suggestions" role="tab">'+ico.bulb+'<span>Fix it</span></button>'
    +     '<button class="panth-pdbg-tab" data-tab="core" role="tab" title="Magento core findings — informational only">⚙ <span>Core</span>'+(counts.coreFindings?'<span class="badge">'+counts.coreFindings+'</span>':'')+'</button>'
    +   '</div>'
    +   '<div class="panth-pdbg-body" data-pdbg-body></div>'
    +   '<div class="panth-pdbg-foot">'
    +     '<span class="stats">'+fmtMs(data.totalMs)+' · '+counts.query+' SQL · '+counts.block+' blocks · '+counts.observer+' observers · '+data.memoryPeakMb+' MB</span>'
    +     '<a href="#" data-pdbg="reload" title="Reload to capture a fresh run">↻ Re-profile</a>'
    +   '</div>'
    + '</div>';
  root.innerHTML = html;

  var panel = root.querySelector('[data-pdbg-panel]');
  var body  = root.querySelector('[data-pdbg-body]');

  // ---------- Render helpers ----------
  var renderModule = function(m){ return m ? '<span class="panth-pdbg-mod">'+esc(m)+'</span>' : ''; };
  var renderKind = function(k){ return '<span class="panth-pdbg-kind '+esc(k)+'">'+esc(k)+'</span>'; };
  var renderCallsites = function(sites){
    if(!sites||!sites.length) return '';
    var rows = sites.map(function(cs,i){
      var trail = (cs.trail||[]).map(function(f,n){
        return '<div class="tline"><span class="tnum">'+(n+1)+'</span><span>'+esc(f.callable||'')+' <span style="color:#94a3b8">('+esc(f.file||'')+(f.line?':'+f.line:'')+')</span></span></div>';
      }).join('');
      var trailId = 'trail-'+Math.random().toString(36).substr(2,6);
      var hasTrail = (cs.trail||[]).length > 1;
      var badge = (cs.count && cs.count>1) ? '<span class="pcount">×'+cs.count+'</span>' : '';
      return '<div class="panth-pdbg-cs" '+(hasTrail?('data-trail-toggle="'+trailId+'" title="Click to expand call trail"'):'')+'>'
        + '<span class="pwhere">'+esc(cs.summary)+'</span>'+badge+'</div>'
        + (hasTrail ? '<div class="panth-pdbg-trail" id="'+trailId+'">'+trail+'</div>' : '');
    }).join('');
    return '<div class="panth-pdbg-callsites">'
      + '<div class="ttl">Called from '+sites.length+' location'+(sites.length>1?'s':'')+'<span style="color:#92400e;font-weight:500">click to expand call trail ▾</span></div>'
      + rows + '</div>';
  };
  var renderBinds = function(binds){
    if(!binds||!binds.length) return '';
    var rows = binds.map(function(b){
      var more = b.distinct > b.sample.length ? ' (+'+(b.distinct-b.sample.length)+' more)' : '';
      return '<div class="row"><span class="bname">'+esc(b.name)+'</span><span class="bvals">'+b.distinct+' distinct values: '+esc(b.sample.join(', '))+more+'</span></div>';
    }).join('');
    return '<div class="panth-pdbg-binds"><div class="ttl">Distinct bind values</div>'+rows+'</div>';
  };
  var renderTiming = function(t){
    if(!t) return '';
    return '<span class="stat">min '+fmtMs(t.min)+'</span><span class="stat">avg '+fmtMs(t.avg)+'</span><span class="stat">max '+fmtMs(t.max)+'</span>';
  };

  // ---------- Tab renderers ----------
  var renderers = {
    overview: function(){
      var a = data.aggregates||{};
      var totalSavings = data.totalEstimatedSavings||0;
      var after = Math.max(0, data.totalMs - totalSavings);
      var card = function(num,lbl,cls){ cls=cls?' '+cls:''; return '<div class="panth-pdbg-card'+cls+'"><div class="num">'+num+'</div><div class="lbl">'+lbl+'</div></div>'; };
      // Userland-only — core findings are informational and live in the Core tab.
      var userland = data.userlandFindings||[];
      var crit = userland.filter(function(f){return f.severity==='critical'||f.severity==='high';}).length;
      var topFindings = userland.slice(0,5);
      var fHtml = '';
      if(topFindings.length){
        fHtml = '<table class="panth-pdbg-table"><thead><tr><th>Severity</th><th>Issue</th><th>Module</th><th>Time</th><th>Saving</th></tr></thead><tbody>';
        topFindings.forEach(function(f){
          fHtml += '<tr><td><span class="panth-pdbg-sev '+esc(f.severity)+'">'+esc(f.severity)+'</span></td>'
                +  '<td>'+esc(f.title)+'</td>'
                +  '<td>'+renderModule(f.module)+'</td>'
                +  '<td style="white-space:nowrap">'+fmtMs(f.measured_ms)+'</td>'
                +  '<td><span class="panth-pdbg-savings">−'+fmtMs(f.estimated_savings_ms)+'</span></td></tr>';
        });
        fHtml += '</tbody></table>';
      } else {
        fHtml = '<div class="panth-pdbg-empty"><span class="ico">✓</span>No bottlenecks detected. Nice page!</div>';
      }
      // Module breakdown — userland only on Overview (Core has its own tab).
      var mHtml = '';
      var topMods = (data.modulesUserland||[]).slice(0,5);
      if(topMods.length){
        var maxModT = topMods[0].time||1;
        mHtml = '<table class="panth-pdbg-table"><thead><tr><th>Module</th><th>Blocks</th><th>SQL</th><th>Obs</th><th>Time</th><th>%</th></tr></thead><tbody>';
        topMods.forEach(function(m){
          var p = pct(m.time, data.totalMs);
          var barCls = p>=20?' bad':(p>=10?' warn':'');
          mHtml += '<tr><td>'+renderModule(m.module)+'</td>'
                +  '<td>'+(m.blocks||0)+'</td><td>'+(m.queries||0)+'</td><td>'+(m.observers||0)+'</td>'
                +  '<td style="white-space:nowrap">'+fmtMs(m.time)+'</td>'
                +  '<td style="width:80px"><div class="panth-pdbg-bar'+barCls+'"><span style="width:'+Math.min(100,(m.time/maxModT)*100)+'%"></span></div><span style="font-size:10px;color:#94a3b8">'+p+'%</span></td></tr>';
        });
        mHtml += '</tbody></table>';
      } else {
        mHtml = '<div class="panth-pdbg-empty" style="padding:16px"><span style="font-size:11px">No third-party / theme modules detected on this page. The Core tab has the Magento internals breakdown.</span></div>';
      }
      return '<div class="panth-pdbg-cards">'
        + card(fmtMs(data.totalMs),'Total time', data.totalMs>1000?'bad':'')
        + card(fmtNum((a.query&&a.query.count)||0),'DB queries')
        + card(fmtMs((a.query&&a.query.time)||0),'DB time')
        + card(fmtNum((a.block&&a.block.count)||0),'Blocks')
        + card(fmtMs((a.block&&a.block.time)||0),'Block render')
        + card(fmtNum((a.observer&&a.observer.count)||0),'Observers')
        + card(data.memoryPeakMb+' MB','Peak memory')
        + card(fmtMs(after),'Time after fixes','savings')
        + '</div>'
        + '<div class="panth-pdbg-section-title"><span>Top issues ('+crit+' critical/high)</span>'
          + (topFindings.length ? '<button class="panth-pdbg-btn ghost" data-go="bottlenecks">See all '+ico.chevR+'</button>' : '')
          + '</div>'
        + fHtml
        + (mHtml ? '<div class="panth-pdbg-section-title"><span>Heaviest modules</span><button class="panth-pdbg-btn ghost" data-go="modules">All modules '+ico.chevR+'</button></div>'+mHtml : '');
    },
    timeline: function(){
      var events = []
        .concat(((data.eventsByKind||{}).controller||[]))
        .concat(((data.eventsByKind||{}).layout||[]))
        .concat(((data.eventsByKind||{}).observer||[]))
        .concat(((data.eventsByKind||{}).block||[]));
      if(!events.length) return '<div class="panth-pdbg-empty"><span class="ico">∅</span>No events recorded yet.</div>';
      events.sort(function(a,b){ return b.duration - a.duration; });
      events = events.slice(0,300);
      var max = events.reduce(function(m,e){return Math.max(m,e.duration);},0)||1;
      var rows = events.map(function(e){
        var p = Math.min(100,(e.duration/max)*100);
        var barCls = e.duration>=50 ? ' bad' : (e.duration>=20 ? ' warn' : '');
        return '<tr><td>'+renderKind(e.kind)+'</td>'
          + '<td><div style="font-weight:600">'+esc(e.label)+'</div>'
          + (e.origin?'<div class="panth-pdbg-mono">'+esc(e.origin)+'</div>':'')
          + '</td>'
          + '<td>'+renderModule(e.module)+'</td>'
          + '<td style="width:25%;min-width:80px"><div class="panth-pdbg-bar'+barCls+'"><span style="width:'+p+'%"></span></div></td>'
          + '<td style="white-space:nowrap;font-weight:600">'+fmtMs(e.duration)+'</td></tr>';
      }).join('');
      return '<div class="panth-pdbg-toolrow">'
        + '<input type="text" placeholder="Filter by name, file, module..." data-pdbg-filter="table">'
        + '<button class="panth-pdbg-btn ghost" data-go="overview">'+ico.chevL+' Overview</button>'
        + '</div>'
        + '<table class="panth-pdbg-table"><thead><tr><th>Kind</th><th>Label & origin</th><th>Module</th><th>Bar</th><th>Time</th></tr></thead><tbody>'+rows+'</tbody></table>';
    },
    queries: function(){
      var qs = ((data.eventsByKind||{}).query)||[];
      if(!qs.length) return '<div class="panth-pdbg-empty"><span class="ico">∅</span>No queries recorded. Enable the DB collector if you expected some.</div>';
      var sorted = qs.slice().sort(function(a,b){return b.duration-a.duration;}).slice(0,300);
      var dupe = {};
      (data.duplicates||[]).forEach(function(d){ dupe[d.fingerprint]=d.count; });
      var rows = sorted.map(function(e,idx){
        var fp = e.meta&&e.meta.fingerprint?e.meta.fingerprint:e.label;
        var dup = dupe[fp]?'<span class="panth-pdbg-sev high" style="margin-left:6px">×'+dupe[fp]+'</span>':'';
        var sevLbl = e.duration>=50?'high':(e.duration>=10?'medium':'low');
        var sqlId = 'sql-'+idx;
        return '<tr><td style="white-space:nowrap;width:120px"><span class="panth-pdbg-sev '+sevLbl+'">'+fmtMs(e.duration)+'</span>'+dup+'</td>'
          + '<td>'
          +   '<div class="panth-pdbg-sql" id="'+sqlId+'">'+esc(e.label)+'</div>'
          +   (e.origin?'<div style="margin-top:4px;display:flex;justify-content:space-between;gap:8px;align-items:center"><span class="panth-pdbg-mono" style="color:#1e40af">↳ '+esc(e.origin)+'</span><button class="panth-pdbg-btn tiny ghost" data-copy="'+sqlId+'">'+ico.copy+' SQL</button></div>':'')
          + '</td></tr>';
      }).join('');
      return '<div class="panth-pdbg-toolrow">'
        + '<input type="text" placeholder="Filter SQL or origin..." data-pdbg-filter="table">'
        + '<button class="panth-pdbg-btn ghost" data-go="overview">'+ico.chevL+' Overview</button>'
        + '</div>'
        + '<table class="panth-pdbg-table"><thead><tr><th>Time</th><th>SQL & origin</th></tr></thead><tbody>'+rows+'</tbody></table>';
    },
    modules: function(){
      var renderTbl = function(mods, label){
        if(!mods.length) return '';
        var maxT = mods[0]&&mods[0].time?mods[0].time:1;
        var rows = mods.map(function(m){
          var p = pct(m.time, data.totalMs);
          var barCls = p>=20?' bad':(p>=10?' warn':'');
          return '<tr><td>'+renderModule(m.module)+'</td>'
            + '<td><span class="panth-pdbg-kind block">'+(m.blocks||0)+'</span></td>'
            + '<td><span class="panth-pdbg-kind query">'+(m.queries||0)+'</span></td>'
            + '<td><span class="panth-pdbg-kind observer">'+(m.observers||0)+'</span></td>'
            + '<td>'+(m.other||0)+'</td>'
            + '<td><div class="panth-pdbg-bar'+barCls+'"><span style="width:'+Math.min(100,(m.time/maxT)*100)+'%"></span></div></td>'
            + '<td style="white-space:nowrap;font-weight:600">'+fmtMs(m.time)+'</td>'
            + '<td style="white-space:nowrap;color:#94a3b8;font-size:11px">'+p+'%</td></tr>';
        }).join('');
        return '<div class="panth-pdbg-section-title"><span>'+label+'</span></div>'
          + '<table class="panth-pdbg-table"><thead><tr><th>Module</th><th>Blocks</th><th>SQL</th><th>Obs</th><th>Other</th><th>Bar</th><th>Time</th><th>%</th></tr></thead><tbody>'+rows+'</tbody></table>';
      };
      var u = data.modulesUserland||[], c = data.modulesCore||[];
      if(!u.length && !c.length) return '<div class="panth-pdbg-empty"><span class="ico">∅</span>Module breakdown not available for this run.</div>';
      return '<div class="panth-pdbg-toolrow">'
        + '<input type="text" placeholder="Filter modules..." data-pdbg-filter="table">'
        + '<button class="panth-pdbg-btn ghost" data-go="overview">'+ico.chevL+' Overview</button>'
        + '</div>'
        + (u.length ? renderTbl(u, 'Your modules ('+u.length+') — actionable') : '<div class="panth-pdbg-empty" style="padding:14px"><span style="font-size:11px">No third-party / theme modules contributing measurable time.</span></div>')
        + (c.length ? renderTbl(c, 'Magento core ('+c.length+') — informational') : '');
    },
    bottlenecks: function(){
      // Userland-only — Magento core findings live in the Core tab.
      var fs = data.userlandFindings||[];
      if(!fs.length) {
        var coreCount = (data.coreFindings||[]).length;
        return '<div class="panth-pdbg-empty"><span class="ico">✓</span>No bottlenecks in your code. Nice page!'
          + (coreCount ? '<div style="margin-top:8px;font-size:11px">' + coreCount + ' Magento core finding(s) — see the <a href="#" data-go="core" style="color:#0f172a;font-weight:600">Core tab</a> if curious.</div>' : '')
          + '</div>';
      }
      var html = '<div class="panth-pdbg-toolrow">'
        + '<input type="text" placeholder="Filter issues..." data-pdbg-filter="issue">'
        + '<button class="panth-pdbg-btn" data-go="suggestions">View fixes '+ico.chevR+'</button>'
        + '</div>';
      html += fs.map(function(f,i){
        var sqlId = 'isql-'+i;
        var inv = (f.invocations && f.invocations>1) ? '<span class="stat">×'+f.invocations+' calls</span>' : '';
        return '<div class="panth-pdbg-issue" data-pdbg-issue>'
          + '<div class="ihead">'
          +   '<div class="ititle"><span class="panth-pdbg-sev '+esc(f.severity)+'" style="margin-right:6px">'+esc(f.severity)+'</span>'+esc(f.title)+(f.module?' '+renderModule(f.module):'')+'</div>'
          +   '<div class="istats"><span class="stat measured">'+fmtMs(f.measured_ms)+'</span>'+inv+(f.timing?renderTiming(f.timing):'')+'<span class="stat saving">−'+fmtMs(f.estimated_savings_ms)+'</span></div>'
          + '</div>'
          + '<div class="panth-pdbg-suggestion">'+esc(f.why)+'</div>'
          + (f.source?'<div class="panth-pdbg-sql" id="'+sqlId+'">'+esc(f.source)+'</div><div style="margin-top:4px;text-align:right"><button class="panth-pdbg-btn tiny ghost" data-copy="'+sqlId+'">'+ico.copy+' Copy SQL</button></div>':'')
          + renderCallsites(f.callsites)
          + renderBinds(f.binds)
          + '<div class="panth-pdbg-fix"><strong>Fix:</strong> '+esc(f.suggestion)+'</div>'
          + '</div>';
      }).join('');
      return html;
    },
    suggestions: function(){
      // Userland-only — fix snippets only matter for code you can change.
      var fs = data.userlandFindings||[];
      if(!fs.length) return '<div class="panth-pdbg-empty"><span class="ico">✓</span>Nothing to optimise in your code — go ship something!</div>';
      var totalSavings = data.totalEstimatedSavings||0;
      var after = Math.max(0, data.totalMs - totalSavings);
      var snippet = function(kind){
        if(kind==='duplicate_query') return "// Cache the resolved set in a request-scoped service\nprivate ?array \$cache = null;\npublic function getOptions(int \$id): array {\n    \$this->cache ??= \$this->repo->getAll();\n    return \$this->cache[\$id] ?? [];\n}";
        if(kind==='slow_query')      return "// 1) EXPLAIN the query in MySQL CLI\n// 2) Add a composite index on (where_col, join_col)\nALTER TABLE my_table ADD INDEX (col_a, col_b);";
        if(kind==='slow_block')      return "// In layout XML: enable block_html cache for this block\n<block class=\"...\" name=\"my.block\" cacheable=\"true\">\n  <arguments>\n    <argument name=\"cache_lifetime\" xsi:type=\"number\">3600</argument>\n  </arguments>\n</block>";
        if(kind==='slow_observer')   return "// Move the heavy work off the synchronous request:\n// 1) Add a queue topic in etc/queue.xml\n// 2) Publish from the observer\n\$this->publisher->publish('my.topic', \$payload);";
        if(kind==='heavy_module')    return "// Audit the module's blocks for cacheability,\n// observers for sync work that can be queued,\n// and repositories for N+1 patterns.";
        return '';
      };
      var rows = fs.map(function(f,i){
        var snipId = 'snip-'+i;
        var snip = snippet(f.kind);
        return '<div class="panth-pdbg-issue">'
          + '<div class="ihead">'
          +   '<div class="ititle"><span class="panth-pdbg-sev '+esc(f.severity)+'" style="margin-right:6px">'+esc(f.severity)+'</span>'+esc(f.title)+(f.module?' '+renderModule(f.module):'')+'</div>'
          +   '<div class="istats"><span class="stat saving">−'+fmtMs(f.estimated_savings_ms)+'</span></div>'
          + '</div>'
          + '<div class="panth-pdbg-suggestion"><strong style="color:#0f172a">Fix:</strong> '+esc(f.suggestion)+'</div>'
          + (snip ? '<pre class="panth-pdbg-sql" id="'+snipId+'" style="margin-top:8px">'+esc(snip)+'</pre><div style="margin-top:4px;text-align:right"><button class="panth-pdbg-btn tiny ghost" data-copy="'+snipId+'">'+ico.copy+' Copy snippet</button></div>' : '')
          + '</div>';
      }).join('');
      return '<div class="panth-pdbg-cards">'
        + '<div class="panth-pdbg-card savings"><div class="num">−'+fmtMs(totalSavings)+'</div><div class="lbl">Total estimated savings</div></div>'
        + '<div class="panth-pdbg-card savings"><div class="num">'+fmtMs(after)+'</div><div class="lbl">Estimated time after fixes</div></div>'
        + '</div>'
        + '<div class="panth-pdbg-toolrow"><button class="panth-pdbg-btn ghost" data-go="bottlenecks">'+ico.chevL+' Back to issues</button></div>'
        + rows;
    },
    core: function(){
      // Magento core findings — informational, not actionable. We surface
      // them so a developer can see what's going on, but they're collapsed
      // by default and clearly labelled as not your fault.
      var fs = data.coreFindings||[];
      if(!fs.length) return '<div class="panth-pdbg-empty"><span class="ico">∅</span>No Magento core findings on this page.</div>';
      var html = '<div style="background:#f1f5f9;border:1px solid #cbd5e1;border-radius:8px;padding:10px 12px;margin-bottom:12px;font-size:11px;color:#475569"><strong>About this tab:</strong> these findings originate inside <code>vendor/magento/*</code>. They cost real time but you usually can\'t fix them without forking framework code. Surface them only when triaging a deeper Magento perf issue.</div>';
      html += '<div class="panth-pdbg-toolrow"><input type="text" placeholder="Filter core findings..." data-pdbg-filter="issue"><button class="panth-pdbg-btn ghost" data-go="bottlenecks">'+ico.chevL+' Your issues</button></div>';
      html += fs.map(function(f,i){
        var sqlId = 'csql-'+i;
        var inv = (f.invocations && f.invocations>1) ? '<span class="stat">×'+f.invocations+' calls</span>' : '';
        return '<div class="panth-pdbg-issue" data-pdbg-issue style="opacity:.85">'
          + '<div class="ihead">'
          +   '<div class="ititle"><span class="panth-pdbg-sev '+esc(f.severity)+'" style="margin-right:6px">'+esc(f.severity)+'</span>'+esc(f.title)+(f.module?' '+renderModule(f.module):'')+'<span class="panth-pdbg-mod" style="background:#fef3c7;color:#92400e;border-color:#fcd34d;margin-left:4px">core</span></div>'
          +   '<div class="istats"><span class="stat measured">'+fmtMs(f.measured_ms)+'</span>'+inv+(f.timing?renderTiming(f.timing):'')+'</div>'
          + '</div>'
          + '<div class="panth-pdbg-suggestion">'+esc(f.why)+'</div>'
          + (f.source?'<div class="panth-pdbg-sql" id="'+sqlId+'">'+esc(f.source)+'</div><div style="margin-top:4px;text-align:right"><button class="panth-pdbg-btn tiny ghost" data-copy="'+sqlId+'">'+ico.copy+' Copy SQL</button></div>':'')
          + renderCallsites(f.callsites)
          + '</div>';
      }).join('');
      return html;
    }
  };

  var current = 'overview';
  var setTab = function(name){
    current = renderers[name] ? name : 'overview';
    Array.prototype.forEach.call(root.querySelectorAll('.panth-pdbg-tab'), function(b){
      b.classList.toggle('active', b.getAttribute('data-tab')===current);
    });
    body.innerHTML = renderers[current]();
    body.scrollTop = 0;
    var inp = body.querySelector('[data-pdbg-filter]');
    if(inp){
      inp.addEventListener('input', function(){
        var q = inp.value.toLowerCase();
        var mode = inp.getAttribute('data-pdbg-filter');
        if(mode==='issue'){
          Array.prototype.forEach.call(body.querySelectorAll('[data-pdbg-issue]'), function(card){
            card.style.display = card.textContent.toLowerCase().indexOf(q)>=0 ? '' : 'none';
          });
        } else {
          var tb = body.querySelector('table tbody');
          if(!tb) return;
          Array.prototype.forEach.call(tb.querySelectorAll('tr'), function(tr){
            tr.style.display = tr.textContent.toLowerCase().indexOf(q)>=0 ? '' : 'none';
          });
        }
      });
    }
  };

  // Event delegation for nav, close, reload, tabs, copy, trail toggle
  root.addEventListener('click', function(e){
    var t = e.target.closest('[data-pdbg]');
    if(t){
      e.preventDefault();
      var op = t.getAttribute('data-pdbg');
      if(op==='open')   panel.classList.add('open');
      if(op==='close')  panel.classList.remove('open');
      if(op==='reload') location.reload();
      return;
    }
    var copy = e.target.closest('[data-copy]');
    if(copy){
      var node = document.getElementById(copy.getAttribute('data-copy'));
      if(node) copyToClipboard(node.textContent);
      return;
    }
    var trail = e.target.closest('[data-trail-toggle]');
    if(trail){
      var t2 = document.getElementById(trail.getAttribute('data-trail-toggle'));
      if(t2) t2.classList.toggle('open');
      return;
    }
    var tab = e.target.closest('[data-tab]');
    if(tab){ setTab(tab.getAttribute('data-tab')); return; }
    var nav = e.target.closest('[data-go]');
    if(nav){ setTab(nav.getAttribute('data-go')); return; }
  });

  document.addEventListener('keydown', function(e){
    if(e.key==='Escape' && panel.classList.contains('open')) panel.classList.remove('open');
  });

  setTab('overview');
})();
</script>
