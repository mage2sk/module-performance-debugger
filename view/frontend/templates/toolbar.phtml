  };

  // ---------- Markup ----------
  var html = ''
    + '<div class="panth-pdbg-launcher '+launcherCls+'" data-pdbg="open" title="Open Performance Debugger — '+counts.findings+' your issues, '+counts.coreFindings+' core findings">'
